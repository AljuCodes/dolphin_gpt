# Copy to .env to override any of these. Every line is optional.
FRONTEND_ORIGIN=http://localhost:3000

# Ollama tuning
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/TrevorJS/gemma-4-E4B-it-uncensored-GGUF:Q4_K_M
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=384
OLLAMA_NUM_BATCH=256
OLLAMA_NUM_THREAD=8
OLLAMA_TEMPERATURE=0.6
OLLAMA_TOP_P=0.9
OLLAMA_PREWARM=1

# Chat/memory speed controls
CHAT_MAX_MESSAGES=12
MEMORY_MAX_ITEMS=12
MEMORY_MAX_CHARS=900
AUTO_EXTRACT_MEMORY=0

# Web search (DuckDuckGo)
WEB_SEARCH_ENABLED=1
WEB_SEARCH_ALWAYS=0
WEB_SEARCH_MAX_RESULTS=4
WEB_SEARCH_TIMEOUT_SECONDS=8
